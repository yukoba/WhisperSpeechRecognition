<Application x:Class="WhisperSpeechRecognition.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             xmlns:local="clr-namespace:WhisperSpeechRecognition"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <!-- タスクトレイのコンテキストメニュー -->
        <ContextMenu x:Key="TrayMenu">
            <!-- <MenuItem Header="設定" Command="{Binding ShowSettingsCommand}" />
            <Separator /> -->
            <MenuItem Header="終了" Command="{Binding ExitApplicationCommand}" />
        </ContextMenu>
        <!-- タスクトレイアイコンの定義 -->
        <tb:TaskbarIcon x:Key="TrayIcon"
                        IconSource="pack://application:,,,/Icon.ico"
                        ToolTipText="Whisper Speech Recognition"
                        Visibility="Visible"
                        ContextMenu="{StaticResource TrayMenu}">
        </tb:TaskbarIcon>
    </Application.Resources>
</Application>
