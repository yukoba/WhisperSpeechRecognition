<Window x:Class="WhisperSpeechRecognition.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OverlayWindow" 
        Height="80" Width="200"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True" 
        IsHitTestVisible="False"
        ShowInTaskbar="False">
    <Grid>
        <Border Background="#CC000000" CornerRadius="10" Padding="15">
            <TextBlock x:Name="StatusText" 
                       Text="🎤 録音中..."
                       Foreground="White" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>